# TrustPipe Docker Configuration
# Copy to .env and customize:
#   cp .env.example .env

# PostgreSQL
POSTGRES_DB=trustpipe
POSTGRES_USER=trustpipe
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# API Server
API_PORT=8000

# Dashboard
DASHBOARD_PORT=8050

